# Required for Web server mode.
OPENAI_API_KEY=your_openai_api_key_here

# Optional: OpenAI-compatible API endpoint.
# OPENAI_API_BASE_URL=https://your-compatible-api.example.com/v1

# Optional: protect public Web deployments.
# APP_PASSWORD=your_password_here

# Optional image storage mode:
# fs: server filesystem, useful for local Web development.
# indexeddb: browser IndexedDB, useful for Vercel/APK-like storage.
NEXT_PUBLIC_IMAGE_STORAGE_MODE=fs
